# ms_home configuration (copy to .env for local dev). No secrets committed.
ENV=dev
PORT=8080
LOG_LEVEL=debug

# Brand applied when the request omits x-brand-id.
DEFAULT_BRAND=LP

# Environment gate for personalization (ANDed with the CMS feature flag).
PERSONALIZATION_ENABLED=false

# Existing Content Service proxy (replaces direct Contentstack access for now).
SHARED_CONTENT_SERVICE_URL=https://content-service.dev.example.com
SHARED_CONTENT_SERVICE_TIMEOUT=5s

# GroupBy (optional). Empty URLs disable the matching product_list strategies.
SHARED_GROUPBY_SEARCH_URL=
SHARED_GROUPBY_RECOMMENDATIONS_URL=
SHARED_GROUPBY_TIMEOUT=5s

# Jewel recommendation service (optional). Empty disables products_list 'jewel'.
SHARED_JEWEL_URL=
SHARED_JEWEL_TIMEOUT=5s

# Salesforce actions service (optional). Empty disables the Salesforce-backed
# strategies (products_cards, recommendation_product_list, product_list-salesforce,
# and the birthday path of container_greeting).
SALESFORCE_MODULE_HTTP=
SALESFORCE_MODULE_TIMEOUT=5s

# ATG cart-header endpoint (optional). Empty disables favorite-store resolution
# (selected_store events) and the continue-buying shortcut.
SHARED_ATG_CART_HEADER_URL=
SHARED_ATG_TIMEOUT=5s

# Search Facade base URL (optional). Empty disables banner_products
# (/getMultiProduct). Similar-item fallback also uses GroupBy recommendations.
SHARED_SEARCH_FACADE_URL=
SHARED_SEARCH_FACADE_TIMEOUT=5s

# Auth (service-side JWT validation). When AUTH_JWKS_URL is set, identity comes
# ONLY from a valid RS256 Bearer token (x-profile-id is ignored). Empty = dev mode
# (identity from the x-profile-id header). Issuer/Audience validated when non-empty.
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_PROFILE_CLAIM=profileId
AUTH_TIMEOUT=5s

# OpenTelemetry tracing. When OTEL_EXPORTER_OTLP_ENDPOINT is set, spans export via
# OTLP (server span + outbound client spans); empty = propagation-only (no export).
# Standard OTEL_* env vars are honored by the exporter.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ms_home
