# ── Service ──────────────────────────────────────────────────────────────
PORT=8080
SERVICE_NAME=ms-home-liverpool
ENVIRONMENT=dev   # dev | qa | staging | prod

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info    # OFF | ERROR | WARN | INFO | DEBUG | TRACE

# ── Content-service proxy ────────────────────────────────────────────────
CONTENT_SERVICE_URL=http://localhost:8090
CONTENT_SERVICE_TIMEOUT_MS=30000
HOME_PAGE_ID=tienda/home   # page slug appended to /content/{type}/{locale}/{page-id}

# ── Defaults ─────────────────────────────────────────────────────────────
DEFAULT_BRAND=LP

# ── Circuit breaker (applied to every outbound call) ────────────────────
BREAKER_FAILURE_RATIO=0.05   # trip at 5% error ratio
BREAKER_MIN_REQUESTS=20      # minimum requests before ratio is evaluated
BREAKER_OPEN_TIMEOUT_S=30    # seconds before half-open probe

# ── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATIO=1.0
